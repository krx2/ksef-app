# =============================================================
# Szablon konfiguracji frontendu — ksef-app
# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# =============================================================

# Adres backendu widoczny z przeglądarki użytkownika (wbudowywany w bundle przy buildzie)
# Przykłady:
#   Lokalnie:       http://localhost:8080
#   Serwer biurowy: http://192.168.1.100:8080
# UWAGA: przy deploymencie przez docker-compose ustaw tę zmienną w backend/.env,
#        a nie tutaj — docker-compose.yml czyta ją stamtąd przy buildzie frontendu.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8080
