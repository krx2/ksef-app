# =============================================================
# Szablon konfiguracji frontendu — ksef-app
# Skopiuj ten plik jako .env.local i uzupełnij wartości.
# =============================================================

# Adres backendu widoczny z serwera Next.js (nie z przeglądarki — wszystkie wywołania API
# przechodzą przez proxy /api/backend/* wewnątrz Next.js).
# W Dockerze: nie ustawiaj — domyślnie http://backend:8080 (wewnętrzna sieć compose).
# Lokalnie (bez Dockera): http://localhost:8080
BACKEND_URL=http://localhost:8080
